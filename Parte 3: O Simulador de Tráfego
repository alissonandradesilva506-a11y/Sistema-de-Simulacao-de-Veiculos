public class SimulVeiculo{
    public abstract class Veiculo{
        protected String marca;
        protected String modelo;
        protected String placa;
        protected int velocidade;
        protected double combustivel;
        protected double consumoPorKm;
        
        public Veiculo(String marca, String modelo, String placa){
            this.marca = marca;
            this.modelo = modelo;
            this.placa = placa;
            this.velocidade = 0;
            this.combustivel = 0;
            this.consumoPorKm = consumoPorKm;
        }
        public String getMarca(){
            return marca;
        }
        public String getModelo(){
            return modelo;
        }
        public String getPlaca(){
            return placa;
        }
        public double getVelocidade(){
            return velocidade;
        }
        public double getCombustivel(){
            return combustivel;
        }
        public double getConsumoPorKm(){
            return consumoPorKm;
        }
        public void setMarca(String marca){
            this.marca = marca;
        }
        public void setModelo(String modelo){
            this.modelo = modelo;
        }
        public void setPlaca(String placa){
            this.placa = placa;
        }
        public void setVelocidade(int velocidade){
            this.velocidade = velocidade;
        }
        public void setCombustivel(double combustivel){
            this.combustivel = combustivel;
        }
        public void setConsumoPorKm(double consumoPorKm){
            this.consumoPorKm = consumoPorKm;
        }
        public void acelerar(){
            this.velocidade += 10;
        }
        public void frear(){
            this.velocidade -= 10;
            if(this.velocidade < 0) this.velocidade=0;
        }
        public void acelerar(int incremento){
            this.velocidade += incremento;
        }
        public void frear(int decremento){
            this.velocidade -= decremento;
            if(this.velocidade < 0) this.velocidade=0;
        }
        public abstract double calcularConsumo(double km);
        public void abastecer(double litros) {
            this.combustivel += litros;
            System.out.println("Abastecido: " + litros + "L. Total: " + this.combustivel + "L.");
        }
        public void abastecer(double litros, String tipoCombustivel) {
            System.out.println("Abastecendo " + tipoCombustivel + "...");
            abastecer(litros);
        }
        @Override
        public String toString() {
            return "Veículo: " + marca + " " + modelo + " - Velocidade: " + velocidade + " km/h";
        }
        public abstract String exibirStatus();
        public void ligar(){
            System.out.println(modelo +" ligado.");
        }
        public void interagir(Veiculo outro) {
            System.out.println(this.getClass().getSimpleName() + " passou direto por " + outro.getClass().getSimpleName());
        }

        public void interagir(Caminhao caminhao) {
            System.out.println("CUIDADO: Veículo pequeno desviando de Caminhão " + caminhao.getPlaca());
        }
    }
    
    public abstract class Carro extends Veiculo{
        private int numPortas;
        public Carro(String marca, String modelo, String placa) {
            super(marca, modelo, placa);
            setVelocidade(0);
            this.numPortas = 4;
        }
        public Carro(String marca, String modelo, String placa, int velocidadeInicial) {
            super(marca, modelo, placa);
            setVelocidade(velocidadeInicial);
            this.numPortas= 4;
        }
        @Override
        public String toString() {
            return "Carro: "+ getMarca() +" "+ getModelo() +" "+ getPlaca()+" - Velocidade: "+ getVelocidade() +" km/h";
        }
        @Override
        public String exibirStatus(){
            return toString()+ "| Portas: "+ numPortas;
        }
        public void ligar(String modo) {
            System.out.println(modelo + " ligado no modo: " + modo);
        }

    }
    public abstract class Moto extends Veiculo{
        private int cilindradas;
        public Moto(String marca, String modelo, String placa) {
            super(marca, modelo, placa);
            setVelocidade(0);
            this.cilindradas = cilindradas;
        }
        public Moto(String marca, String modelo, String placa, int velocidadeInicial) {
            super(marca, modelo, placa);
            setVelocidade(velocidadeInicial);
            this.cilindradas = cilindradas;
        }
        @Override
        public void acelerar(){
            this.velocidade += 15;
        }
        @Override
        public void frear(){
            this.velocidade -= 15;
            if(this.velocidade < 0) this.velocidade=0;
        }
        @Override
        public String toString() {
            return "Moto: "+ getMarca() +" "+ getModelo() +" "+ getPlaca() +" - Velocidade: "+ getVelocidade() +" km/h";
        }
        @Override
        public String exibirStatus(){
            return toString()+ "| Portas: "+ cilindradas;
        }
    }
    public abstract class Caminhao extends Veiculo{
        public Caminhao(String marca, String modelo, String placa) {
            super(marca, modelo, placa);
            setVelocidade(0);
        }
        public Caminhao(String marca, String modelo, String placa, int velocidadeInicial) {
            super(marca, modelo, placa);
            setVelocidade(velocidadeInicial);
        }
        @Override
        public double calcularConsumo(double km) {
            return km * getConsumoPorKm() * 1.5;
        }
        @Override
        public String toString() {
            return "Caminhão: "+ getMarca() +" "+ getModelo() +" "+ getPlaca() +" - Velocidade: "+ getVelocidade() +" km/h";
        }
    }
    public class Garagem{
        private Veiculo[] vagas;
        private int proximaVaga;
        
        public Garagem(int tamanho){
            this.vagas = new Veiculo[tamanho];
            this.proximaVaga = 0;
        }
        public void estacionarCarro(int vaga, Veiculo carro){
            if (vaga >= 0 && vaga < vagas.length){
                vagas[vaga] = carro;
                System.out.println("Carro estacionado na vaga "+vaga);
            }else{
                System.out.println("Vaga inválida.");
            }
        }
        public void estacionarMoto(int vaga, Veiculo moto){
            if (vaga >= 0 && vaga < vagas.length){
                vagas[vaga] = moto;
                System.out.println("Carro estacionado na vaga "+vaga);
            }else{
                System.out.println("Vaga inválida.");
            }
        }
        public void listarGaragem(){
            System.out.println("--- Relatório da Garagem ---");
            for (int i=0; i < vagas.length; i++){
                if (vagas[i] !=null){
                    System.out.println("Vaga "+ i +": "+ vagas[i].toString());
                }else{
                    System.out.println("Vaga "+ i +": vazia");
                }
            }
        }
        public void listarVeiculos() {
            System.out.println("\n--- Status da Garagem ---");
            for (int i = 0; i < proximaVaga; i++) {
                vagas[i].exibirStatus(); 
            }
        }
    }
    public class SimuladorDeTrafego{
        private Veiculo[] pista;
        private int totalVeiculos;
        
        public SimuladorDeTrafego(int tamanhoPista) {
            this.pista = new Veiculo[tamanhoPista];
            this.totalVeiculos = 0;
        }
        public void adicionarVeiculo(Veiculo v) {
            if (totalVeiculos < pista.length) {
                pista[totalVeiculos] = v;
                totalVeiculos++;
            } else {
                System.out.println("Erro: Pista cheia! Não é possível adicionar " + v.placa);
            }
        }
        public void iniciarSimulacao() {
            for (int i = 0; i < totalVeiculos; i++) {
                for (int j = 0; j < totalVeiculos; j++) {
                    if (i != j) {
                        pista[i].interagir(pista[j]);
                    }
                }
            }
        }
    }
}
